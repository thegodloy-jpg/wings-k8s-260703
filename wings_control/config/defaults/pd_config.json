{
  "_comment": "PD 分离模型配置注册表。key = 模型架构 (model_architecture)，同时作为 external-lb PD 的门控白名单：取不到条目 = 未注册 = 不应用 PD external-lb（走原 standalone）。新增一个模型的 PD 支持 = 在此加一个架构条目，无需改 Python。各字段语义见 docs/xuqiu/deepseek-v32-pd-disaggregation.md §7.6。数值来源为 vllm-ascend 官方 tutorials，以官方文档为准（部分经摘要，落地前需逐项核对）。",
  "_schema": {
    "<ModelArchitecture>": {
      "connector": "KV 连接器名 (MooncakeLayerwiseConnector | MooncakeConnectorV1 | ...)",
      "kv_port": { "P": "producer 端口", "D": "consumer 端口" },
      "extra_config": "kv_connector_extra_config 的模型专属附加字段 (prefill/decode 全局拓扑由运行时按角色填入，不写这里)",
      "common": "P/D 共用的 engine 参数",
      "prefill": { "engine": "P 专属 engine 参数", "env": "P 专属环境变量" },
      "decode": { "engine": "D 专属 engine 参数", "env": "D 专属环境变量" }
    }
  },
  "pd_config": {
    "default": {
      "_comment": "未注册模型的 PD 分离兜底模板。仅含通用安全项；特定模型应单独注册条目覆盖。刻意不含 gpu_memory_utilization / enable_expert_parallel（非 MoE 会报错）/ max_num_* / 模型专属算子项。connector=MooncakeConnectorV1 时 engine_id 由运行时按 dp_rank 注入（见设计文档 §8-C2）。FULL_DECODE_ONLY 有 MTE 越界历史(R6)，新模型首次跑建议真机验证，必要时用专属条目覆盖为 enforce_eager。",
      "connector": "MooncakeConnectorV1",
      "kv_port": { "P": "30100", "D": "30400" },
      "extra_config": {},
      "common": { "trust_remote_code": true, "disable_hybrid_kv_cache_manager": true },
      "prefill": { "engine": { "enforce_eager": true }, "env": {} },
      "decode": {
        "engine": { "compilation_config": { "cudagraph_mode": "FULL_DECODE_ONLY" } },
        "env": { "TASK_QUEUE_ENABLE": "1" }
      }
    },
    "Qwen3MoeForCausalLM": {
      "_source": "用户自定义 3P1D launch_online_dp / run_dp_template.sh 对齐；Qwen3-30B-A3B。external-lb(DP fork)专用条目。",
      "_confirm": "落地前需真机确认的值：quantization(当前 platform 跑的是非量化 dtype=auto，故此处不设 ascend；若权重是 w8a8 再加 quantization=ascend)；disable_hybrid_kv_cache_manager=false(对齐模板 --no-disable，与 default 的 true 相反)；decode 的 max_num_batched_tokens/max_num_seqs 沿用模板 120/60，按真机吞吐再调；prefill/decode 的 HCCL 超时与 buffer 取自模板。",
      "connector": "MooncakeLayerwiseConnector",
      "kv_port": { "P": "30000", "D": "30100" },
      "extra_config": {},
      "kv_buffer_device": "npu",
      "common": {
        "trust_remote_code": true,
        "enable_expert_parallel": true,
        "disable_hybrid_kv_cache_manager": false
      },
      "prefill": {
        "engine": {
          "max_num_batched_tokens": 8192,
          "max_num_seqs": 4,
          "gpu_memory_utilization": 0.9,
          "enforce_eager": true,
          "additional_config": { "enable_cpu_binding": "True" }
        },
        "env": {
          "HCCL_INTRA_ROCE_ENABLE": "1",
          "USE_MULTI_GROUPS_KV_CACHE": "1",
          "USE_MULTI_BLOCK_POOL": "1",
          "ASCEND_BUFFER_POOL": "4:8",
          "HCCL_BUFFSIZE": "2560",
          "TASK_QUEUE_ENABLE": "1",
          "VLLM_RPC_TIMEOUT": "3600000",
          "VLLM_EXECUTE_MODEL_TIMEOUT_SECONDS": "30000",
          "HCCL_EXEC_TIMEOUT": "204",
          "HCCL_CONNECT_TIMEOUT": "120"
        }
      },
      "decode": {
        "engine": {
          "max_num_batched_tokens": 120,
          "max_num_seqs": 60,
          "gpu_memory_utilization": 0.88,
          "enable_prefix_caching": true,
          "async_scheduling": true,
          "compilation_config": { "cudagraph_mode": "FULL_DECODE_ONLY" }
        },
        "env": {
          "HCCL_INTRA_ROCE_ENABLE": "1",
          "VLLM_ASCEND_ENABLE_FUSED_MC2": "1",
          "USE_MULTI_GROUPS_KV_CACHE": "1",
          "USE_MULTI_BLOCK_POOL": "1",
          "ASCEND_BUFFER_POOL": "4:8",
          "HCCL_BUFFSIZE": "1024",
          "TASK_QUEUE_ENABLE": "1",
          "VLLM_RPC_TIMEOUT": "3600000",
          "VLLM_EXECUTE_MODEL_TIMEOUT_SECONDS": "30000",
          "HCCL_EXEC_TIMEOUT": "2000",
          "HCCL_CONNECT_TIMEOUT": "1200"
        }
      }
    },
    "DeepseekV32ForCausalLM": {
