        "VLLM_EXECUTE_MODEL_TIMEOUT_SECONDS": "30000",
        "HCCL_EXEC_TIMEOUT": "2000",
        "HCCL_CONNECT_TIMEOUT": "1200"
      },
      "common": {
        "enable_expert_parallel": true,
        "quantization": "ascend",
        "seed": 1024,
        "async_scheduling": true,
        "enable_auto_tool_choice": true,
        "tool_call_parser": "glm47",
        "reasoning_parser": "glm45",
        "speculative_config": { "num_speculative_tokens": 3, "method": "deepseek_mtp" }
      },
      "prefill": {
        "engine": {
          "max_model_len": 115168,
          "max_num_batched_tokens": 4096,
          "max_num_seqs": 64,
          "gpu_memory_utilization": 0.95,
          "enforce_eager": true,
          "enable_prefix_caching": false,
          "enable_chunked_prefill": true,
          "compilation_config": null,
          "additional_config": {
            "enable_sparse_c8": false,
            "fuse_muls_add": true,
            "multistream_overlap_shared_expert": true,
            "recompute_scheduler_enable": true,
            "ascend_compilation_config": { "enable_npugraph_ex": true },
            "enable_dsa_cp": true
          }
        },
        "env": { "VLLM_ASCEND_ENABLE_FLASHCOMM1": "1", "HCCL_BUFFSIZE": "256", "VLLM_NIXL_ABORT_REQUEST_TIMEOUT": "300000" }
      },
      "decode": {
        "engine": {
          "max_model_len": 135168,
          "max_num_batched_tokens": 164,
          "max_num_seqs": 48,
          "gpu_memory_utilization": 0.92,
          "enable_prefix_caching": false,
          "enable_chunked_prefill": false,
          "compilation_config": { "cudagraph_mode": "FULL_DECODE_ONLY" },
          "additional_config": {
            "enable_sparse_c8": false,
            "fuse_muls_add": true,
            "multistream_overlap_shared_expert": true,
            "recompute_scheduler_enable": true,
            "ascend_compilation_config": { "enable_npugraph_ex": true }
          }
        },
        "env": { "VLLM_ASCEND_ENABLE_MLAPO": "1", "TASK_QUEUE_ENABLE": "1", "HCCL_BUFFSIZE": "500" }
      },
      "platform_overrides": {
        "_comment": "基条目为 GLM-5.1 / A3 口径。A2(910b) overlay：①前缀缓存两端开(GLM-5.2 口径，覆盖基条目 false)；②decode 开 DYNAMIC_EPLB；③strip_env 剔除官方 A2 不设的多余 env(VLLM_USE_V1/VLLM_LLMDD_RPC_PORT/VLLM_MOONCAKE_BOOTSTRAP_PORT/ASCEND_CONNECT_TIMEOUT/ASCEND_TRANSFER_TIMEOUT/ASCEND_A3_ENABLE；prefill 另剔 TASK_QUEUE_ENABLE——官方 P 不设、D 保留)，VLLM_MOONCAKE_BOOTSTRAP_PORT 连 fork 内联前缀一并省去。HCCL_BUFFSIZE 已角色化到 prefill/decode.env(P=256/D=500)，不在此 overlay 设。⚠️ 刻意【不】设 VLLM_ASCEND_BALANCE_SCHEDULING：PD 分离下 vLLM-Ascend≥0.20.2 会 ValidationError(presence-based，0 也崩)，vllm_adapter._filter_pd_incompatible_env 会统一剔除——若在此 overlay 重新注入会经 _pd_env 绕过该过滤器、复活已被 b21bf74 修掉的崩溃。仅当 _resolve_ascend_platform() 解析为 'a2'(WINGS_ASCEND_PLATFORM=a2 等)时经 _merge_configs 深合并生效；a3/无信号不应用→基条目 A3 行为字节级不变。⚠️ overlay 按架构命中，GLM-5.1 on A2 也会被套用(前缀缓存被开)，若 5.1/5.2 需在 A2 共存须在 _apply_pd_external_lb 加 is_glm52 门控。",
        "a2": {
          "strip_env": ["VLLM_USE_V1", "VLLM_LLMDD_RPC_PORT", "VLLM_MOONCAKE_BOOTSTRAP_PORT", "ASCEND_CONNECT_TIMEOUT", "ASCEND_TRANSFER_TIMEOUT", "ASCEND_A3_ENABLE"],
          "prefill": { "engine": { "enable_prefix_caching": true }, "strip_env": ["TASK_QUEUE_ENABLE"] },
          "decode": {
            "engine": { "enable_prefix_caching": true },
            "env": { "DYNAMIC_EPLB": "1" }
          }
        }
      }
